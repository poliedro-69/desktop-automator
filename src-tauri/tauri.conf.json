{
  "productName": "DesktopAutomator",
  "version": "1.0.3",
  "identifier": "com.desktopautomator.com",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Desktop Automator",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../public/help.html",
      "../public/help-en.html",
      "stripe.key"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFGRDMwMDExQTk5RDQ4MTAKUldRUVNKMnBFUURUSDUxOHNXK2FFNWZWWjhiTjdMd2h2TSt0Vjl5SUNCMTJEenlpTUx5eUFUbDQK",
      "endpoints": [
        "https://github.com/poliedro-69/desktop-automator/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  }
}
