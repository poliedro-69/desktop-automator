# ══════════════════════════════════════════════════════════════════════════════
# Dependencies
# ══════════════════════════════════════════════════════════════════════════════
node_modules/

# ══════════════════════════════════════════════════════════════════════════════
# Build output
# ══════════════════════════════════════════════════════════════════════════════
dist/
src-tauri/target/
src-tauri/gen/schemas/

# ══════════════════════════════════════════════════════════════════════════════
# Signing keys (NEVER commit these)
# ══════════════════════════════════════════════════════════════════════════════
*.key
*.key.pub
*.pfx
*.p12
stripe.key
src-tauri/.signing-key
src-tauri/.signing-key.pub

# ══════════════════════════════════════════════════════════════════════════════
# Secrets & API keys
# ══════════════════════════════════════════════════════════════════════════════
.env
.env.*
!.env.example

# ══════════════════════════════════════════════════════════════════════════════
# IDE & editor
# ══════════════════════════════════════════════════════════════════════════════
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ══════════════════════════════════════════════════════════════════════════════
# OS files
# ══════════════════════════════════════════════════════════════════════════════
Thumbs.db
Desktop.ini
.DS_Store

# ══════════════════════════════════════════════════════════════════════════════
# Logs & temp
# ══════════════════════════════════════════════════════════════════════════════
*.log
npm-debug.log*

# ══════════════════════════════════════════════════════════════════════════════
# Rust
# ══════════════════════════════════════════════════════════════════════════════
src-tauri/Cargo.lock

# ══════════════════════════════════════════════════════════════════════════════
